rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    // Rule เบื้องต้นสำหรับระบบ PIN ภายในร้านที่ใช้ Anonymous Auth
    // หมายเหตุ: สิทธิ์ owner/manager/employee ตรวจในแอปฝั่ง client เป็นหลัก
    // ถ้าต้องการ security ระดับองค์กร ควรย้าย logic สำคัญไป Cloud Functions + Custom Claims
    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
